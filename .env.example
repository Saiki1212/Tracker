# Optional CORS origin override (only needed if frontend served on a different host)
FRONTEND_ORIGIN=

# Local dev port for dev-server.js (Vercel ignores this)
PORT=5174

# ===== Task Reminder Automation =====

# Public URL of the deployed Forge UI (used in reminder email CTA buttons)
FRONTEND_URL=https://forge-nine-lime.vercel.app/app.html

# Random hex secret used to authenticate Vercel Cron requests.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be set in Vercel Project → Settings → Environment Variables; Vercel
# automatically forwards it as `Authorization: Bearer ${CRON_SECRET}` to
# scheduled cron endpoints when the env var is named CRON_SECRET.
CRON_SECRET=replace-with-a-long-random-hex-string

# Gmail SMTP credentials for outgoing reminder emails.
# Use a Google App Password (NOT your real password):
#   https://myaccount.google.com/apppasswords
# (Requires 2FA enabled on the Google account.)
SMTP_EMAIL=you@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
